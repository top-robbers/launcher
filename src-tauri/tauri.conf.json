{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Top Robbers Launcher",
	"version": "../package.json",
	"identifier": "com.top-robbers.launcher",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Top Robbers Launcher",
				"userAgent": "top-robbers-launcher",
				"width": 1280,
				"height": 800,
				"minWidth": 1280,
				"minHeight": 800,
				"decorations": false,
				"transparent": true,
				"dragDropEnabled": false,
				"center": true,
				"shadow": false,
				"visible": false
			},
			{
				"label": "splashscreen",
				"title": "Top Robbers Launcher",
				"url": "/splashscreen",
				"width": 520,
				"height": 420,
				"minWidth": 520,
				"minHeight": 420,
				"decorations": false,
				"transparent": true,
				"dragDropEnabled": false,
				"resizable": false,
				"center": true,
				"shadow": false,
				"alwaysOnTop": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["msi", "nsis"],
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
		"createUpdaterArtifacts": true
	}
}
